# ─────────────────────────────────────────────────────────────
# Variables de entorno — Portal Subdirección de Investigaciones IIAP
# Copia este archivo como `.env.local` (desarrollo) o configúralas en el
# panel del hosting (Render / servidor del área de sistemas).
# NUNCA subas el archivo con valores reales al repositorio.
# ─────────────────────────────────────────────────────────────

# ── Sanity CMS (contenido de Actualidades) ──────────────────────
# Valores públicos del proyecto Sanity (visibles en el cliente).
NEXT_PUBLIC_SANITY_PROJECT_ID=tu_project_id
NEXT_PUBLIC_SANITY_DATASET=production

# Token de LECTURA de Sanity — SECRETO, solo servidor. No lleva prefijo
# NEXT_PUBLIC_ y no debe exponerse en el cliente.
SANITY_API_READ_TOKEN=tu_token_de_solo_lectura

# ── Dominio del sitio ───────────────────────────────────────────
# ORIGEN (dominio) de PRODUCCIÓN, SIN ruta ni barra final. Afecta sitemap.xml,
# robots.txt, canonical y Open Graph / Twitter.
# En el preview de Render puede apuntar a la URL *.onrender.com.
NEXT_PUBLIC_SITE_URL=https://iiap.org.co

# ── Subruta de integración ──────────────────────────────────────
# El portal se integra bajo la subruta institucional /investigacion.
# Definir en PRODUCCIÓN real; debe coincidir con basePath (next.config.ts).
# Dejar SIN definir en el preview de Render (se sirve en la raíz).
# NEXT_PUBLIC_BASE_PATH=/investigacion

# ── Guard de indexación en buscadores ───────────────────────────
# Por defecto (sin definir o "false") el sitio es NOINDEX: ideal para el
# preview de Render y cualquier entorno que no sea la producción real.
# Ponlo en "true" ÚNICAMENTE en el dominio definitivo para permitir que
# Google y otros buscadores indexen el sitio.
NEXT_PUBLIC_ALLOW_INDEXING=false
